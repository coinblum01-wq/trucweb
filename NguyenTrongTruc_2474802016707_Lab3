      "source": [
        "#3. Dữ liệu cột chứa các giá trị đơn vị không nhất quán\n",
        "def convert_weight_to_kg(weight_str):\n",
        "    if pd.isna(weight_str):\n",
        "        return weight_str\n",
        "    weight_str = str(weight_str).lower().strip()\n",
        "    if 'lbs' in weight_str:\n",
        "        num = float(weight_str.replace('lbs', '').strip())\n",
        "        return round(num * 0.453592, 2) # Đổi lbs -> kg\n",
        "    elif 'kgs' in weight_str:\n",
        "        return float(weight_str.replace('kgs', '').strip())\n",
        "    else:\n",
        "        # Nếu chỉ có số thuần túy, coi như đã là kg\n",
        "        try:\n",
        "            return float(weight_str)\n",
        "        except:\n",
        "            return None\n",
        "\n",
        "df['Weight'] = df['Weight'].apply(convert_weight_to_kg)"
      ],
