      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Tạo dữ liệu mẫu\n",
        "np.random.seed(42)\n",
        "n = 500\n",
        "ma_kh = [f'KH{i:03d}' for i in range(1, n + 1)]\n",
        "tuoi = np.random.randint(18, 71, n).astype(float)\n",
        "tuoi[np.random.choice(n, 10, replace=False)] = np.nan\n",
        "thu_nhap = np.random.uniform(5, 50, n)\n",
        "thu_nhap[np.random.choice(n, 5, replace=False)] = 200\n",
        "gioi_tinh = np.random.choice(['Nam', 'Nữ'], n)\n",
        "gioi_tinh[np.random.choice(n, 15, replace=False)] = np.nan\n",
        "thanh_pho = np.random.choice(['Hà Nội', 'Đà Nẵng', 'TP.HCM'], n)\n",
        "tong_chi_tieu = (thu_nhap * 0.5) + np.random.normal(0, 5, n)\n",
        "\n",
        "df_khachhang = pd.DataFrame({\n",
        "    'MaKH': ma_kh, 'Tuoi': tuoi, 'ThuNhap': thu_nhap,\n",
        "    'GioiTinh': gioi_tinh, 'ThanhPho': thanh_pho, 'TongChiTieu': tong_chi_tieu\n",
        "})\n",
        "print(df_khachhang.head())"
