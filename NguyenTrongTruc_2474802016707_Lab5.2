    {
      "cell_type": "markdown",
      "source": [
        "**kiến trúc model**"
      ],
      "metadata": {
        "id": "yhwKslHUuDz0"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class MNIST_CNN(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.conv1 = nn.Conv2d(1, 16, kernel_size=3, stride=1, padding=0)   # 28→26\n",
        "        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, stride=1, padding=0)  # 13→11\n",
        "        self.pool  = nn.MaxPool2d(kernel_size=2, stride=2)\n",
        "        self.fc1   = nn.Linear(32 * 5 * 5, 10)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.pool(torch.relu(self.conv1(x)))   # → (16, 13, 13)\n",
        "        x = self.pool(torch.relu(self.conv2(x)))   # → (32,  5,  5)\n",
        "        x = x.view(x.size(0), -1)                  # flatten\n",
        "        x = self.fc1(x)                            # logits\n",
        "        return x\n",
        "\n",
        "model = MNIST_CNN().to(device)\n",
        "n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
        "print(model)\n",
        "print(f'Tổng tham số: {n_params:,}')\n",
        "\n",
        "# So sánh nhanh với ANN(784→128→10) ở bài trước: ~101 nghìn params và ~97% acc.\n",
        "# CNN này thường ít tham số hơn (~13 nghìn) mà acc cao hơn."
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "sJflXk7NtJ97",
        "outputId": "caebc941-7f3a-428f-e594-c80e5376eac1"
      },
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "MNIST_CNN(\n",
            "  (conv1): Conv2d(1, 16, kernel_size=(3, 3), stride=(1, 1))\n",
            "  (conv2): Conv2d(16, 32, kernel_size=(3, 3), stride=(1, 1))\n",
            "  (pool): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n",
            "  (fc1): Linear(in_features=800, out_features=10, bias=True)\n",
            ")\n",
            "Tổng tham số: 12,810\n"
          ]
        }
      ]
