        "plt.xticks(rotation=90)\n",
        "plt.legend(title=\"Phanlopt1\")\n",
        "plt.grid(True, linestyle=':', alpha=0.6)\n",
        "plt.show()\n",
        "\n",
        "\n",
        "# 5. Vẽ biểu đồ Drop-line cho biến T1 được phân loại bởi biến phanlopt1\n",
        "# Trong matplotlib, biểu đồ Drop-line (cột có đường kẻ đứng mảnh nối từ mốc 0 lên chấm tròn) được vẽ bằng hàm stem()\n",
        "plt.figure(figsize=(12, 6))\n",
